# Copy this file to backend/.env and fill in real values locally.
# Never commit real keys, tokens, passwords, or access credentials.

LLM_PROVIDER=ark

# Volcengine Ark / Doubao
ARK_API_KEY=replace_me
ARK_OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-1-pro-260628

# Volcengine VEI
VEI_API_KEY=
VEI_BASE_URL=https://ai-gateway.vei.volces.com/v1
VEI_MODEL=doubao-1.5-lite-32k

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Speech-to-text
STT_PROVIDER=volc_seedasr
STT_MODEL=bigmodel

VOLC_ASR_API_KEY=
VOLC_ASR_APP_KEY=replace_with_app_id
VOLC_ASR_ACCESS_KEY=replace_with_access_token
VOLC_ASR_SECRET_KEY=replace_with_secret_key

VOLC_ASR_RESOURCE_ID=volc.seedasr.auc
VOLC_ASR_MODEL=bigmodel
VOLC_ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
VOLC_ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
VOLC_ASR_POLL_INTERVAL_SEC=1.0
VOLC_ASR_MAX_POLLS=20

OPENAI_STT_MODEL=whisper-1
ARK_STT_MODEL=
VEI_STT_MODEL=

# LangSmith / LangChain
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=replace_me
LANGSMITH_PROJECT=smartcane

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=replace_me
LANGCHAIN_PROJECT=smartcane

# Amap
AMAP_WEB_KEY=replace_me
AMAP_ANDROID_KEY=replace_me

# Database
# SMARTCANE_DB_PATH=/root/smart_cane/backend/smartcane.db
